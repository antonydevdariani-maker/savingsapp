{
  "expo": {
    "name": "SweatLock",
    "slug": "sweatlock",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "sweatlock",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.sweatlock.app",
      "infoPlist": {
        "NSCameraUsageDescription": "SweatLock uses the camera to count your pushup reps via AI pose detection.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "SweatLock uses your camera to count pushup reps."
        }
      ],
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "cfcee07a-693e-4546-ba9c-ffe5464e017f"
      }
    },
    "newArchEnabled": false
  }
}
