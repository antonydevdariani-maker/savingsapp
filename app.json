{
  "expo": {
    "name": "SweatLock",
    "slug": "sweatlock",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "sweatlock",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.sweatlock.app",
      "infoPlist": {
        "NSCameraUsageDescription": "SweatLock uses the camera to count your pushup reps via AI pose detection."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "permissions": ["android.permission.CAMERA"]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      ["expo-camera", { "cameraPermission": "SweatLock uses your camera to count pushup reps." }]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
